DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DATABASE_URL=postgres://ztp:ztp@db:5432/ztp
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Bluecat IPAM REST API v2
BLUECAT_BASE_URL=https://bluecat.example.net/api/v2
BLUECAT_USERNAME=ztp-svc
BLUECAT_PASSWORD=
BLUECAT_VERIFY_TLS=True
BLUECAT_DEFAULT_CONFIG=Production
BLUECAT_LOOPBACK_TAG_GROUP=ZTP/Loopbacks
BLUECAT_P2P_TAG_GROUP=ZTP/P2P-Networks

# Opengear console server
OPENGEAR_BASE_URL=https://console.example.net/api/v2
OPENGEAR_USERNAME=ztp-svc
OPENGEAR_PASSWORD=
OPENGEAR_VERIFY_TLS=True

# ZTP file server
ZTP_FILES_ROOT=/srv/ztp_files
ZTP_PUBLIC_BASE_URL=http://ztp.example.net
ZTP_REQUIRE_AUTH=False

# Git mirror for rendered configs (optional audit trail)
GIT_MIRROR_ENABLED=False
GIT_MIRROR_PATH=/srv/config_repo
GIT_MIRROR_REMOTE=
GIT_MIRROR_AUTHOR_NAME=ZTP Bot
GIT_MIRROR_AUTHOR_EMAIL=ztp@example.net
